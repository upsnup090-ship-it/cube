# ──────────────────────────────────────────────────────────────────────────────
# BigPlayBot Dices — Environment Variables Example
#
# Copy this file to `.env.local` for local development.
# DO NOT commit `.env.local` or any file containing real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Admin panel ───────────────────────────────────────────────────────────────
# HTTP Basic Auth credentials for /admin/*
# In production, BOTH variables must be set, otherwise /admin returns 503.
# In development, /admin is accessible without auth if both vars are empty.
#
# Generate a strong password:
#   openssl rand -base64 24
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── Telegram ──────────────────────────────────────────────────────────────────
# Webhook secret — required in production.
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Bot token from @BotFather — required for any real Telegram interaction.
TELEGRAM_BOT_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite is used by default for local dev (file:./dev.db is hardcoded in
# src/server/db/prisma.ts). When migrating to Postgres, set DATABASE_URL.
# DATABASE_URL=postgresql://user:password@localhost:5432/cube_dev
