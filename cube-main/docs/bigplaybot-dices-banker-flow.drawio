        <mxCell id="e11" value="yes" edge="1" parent="1" source="ok" target="accepted"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" edge="1" parent="1" source="accepted" target="wait"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e13" value="early cancel" edge="1" parent="1" source="wait" target="cancel_timer"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e14" value="opponent joined" edge="1" parent="1" source="wait" target="both"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e15" value="second player" edge="1" parent="1" source="join" target="both"><mxGeometry relative="1" as="geometry"/></mxCell>
