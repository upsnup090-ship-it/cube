  <diagram name="BigPlayBot Dices Flow" id="page1">
    <mxGraphModel dx="2200" dy="1800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="3300" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="start" value="/dices in private chat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;" vertex="1" parent="1"><mxGeometry x="920" y="40" width="300" height="70" as="geometry"/></mxCell>
        <mxCell id="lobby" value="Dices lobby: create game or choose active game" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1"><mxGeometry x="850" y="160" width="450" height="90" as="geometry"/></mxCell>
        <mxCell id="list" value="Active games list: games created by players. User can click an existing game and play." style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="820" y="300" width="510" height="110" as="geometry"/></mxCell>
        <mxCell id="choice" value="Player action?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1"><mxGeometry x="990" y="470" width="160" height="120" as="geometry"/></mxCell>
        <mxCell id="join" value="Scenario A: click active game and join as second player" style="whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="350" y="690" width="360" height="100" as="geometry"/></mxCell>
        <mxCell id="create" value="Scenario B: create own game" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1340" y="700" width="310" height="80" as="geometry"/></mxCell>
        <mxCell id="amount" value="Choose or send bet amount. Limit depends on balance. Example: 1 to 18 RUB." style="shape=parallelogram;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1260" y="850" width="470" height="110" as="geometry"/></mxCell>
        <mxCell id="dicecount" value="Choose dice count: 1 die or 2 dice. Pressing button toggles mode. Cancel is available." style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1260" y="1010" width="470" height="120" as="geometry"/></mxCell>
        <mxCell id="confirm" value="Bet confirmation: bot shows BTC equivalent and asks to confirm." style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1260" y="1180" width="470" height="100" as="geometry"/></mxCell>
        <mxCell id="ok" value="Confirmed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1415" y="1340" width="160" height="120" as="geometry"/></mxCell>
        <mxCell id="cancel" value="Cancel: return to lobby" style="whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1780" y="1360" width="250" height="80" as="geometry"/></mxCell>
        <mxCell id="accepted" value="Bet accepted. Bot creates game ID and decreases user balance by bet amount." style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1260" y="1520" width="470" height="100" as="geometry"/></mxCell>
        <mxCell id="wait" value="Game appears in active list and waits for opponent." style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1260" y="1680" width="470" height="90" as="geometry"/></mxCell>
        <mxCell id="cancel_timer" value="Creator can cancel own bet after 1 minute. Earlier bot shows remaining seconds." style="whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1780" y="1670" width="410" height="100" as="geometry"/></mxCell>
        <mxCell id="both" value="Both players paid same bet. Max players: 2. Bank = bet x 2." style="whiteSpace=wrap;html=1;fillColor=#97d077;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="850" y="1930" width="470" height="100" as="geometry"/></mxCell>
        <mxCell id="roll" value="Bot starts draw: Dices #ID, Bank: X RUB, Rolling dice..." style="whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1"><mxGeometry x="850" y="2090" width="470" height="100" as="geometry"/></mxCell>
        <mxCell id="tg" value="Result is generated by Telegram Dice. 1 die = one dice message. 2 dice = two dice messages." style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1"><mxGeometry x="830" y="2250" width="510" height="110" as="geometry"/></mxCell>
        <mxCell id="sum" value="For 2 dice, result is sum of two dice." style="whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="880" y="2420" width="410" height="80" as="geometry"/></mxCell>
        <mxCell id="equal" value="Equal results?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1000" y="2560" width="160" height="120" as="geometry"/></mxCell>
        <mxCell id="reroll" value="Draw: reroll until winner is determined." style="whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1"><mxGeometry x="520" y="2575" width="350" height="90" as="geometry"/></mxCell>
        <mxCell id="winner" value="Winner is player with higher result." style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="850" y="2750" width="470" height="80" as="geometry"/></mxCell>
        <mxCell id="payout" value="Winner receives whole bank. Final message shows bank, results, win/loss and balance." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#97d077;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="830" y="2890" width="510" height="110" as="geometry"/></mxCell>
