# ─── BigPlayBot Dices — environment variables ────────────────────────────────
#
# Скопируйте этот файл в .env и заполните значения.
# НЕ КОММИТЬТЕ .env в репозиторий.
#
# Поведение при отсутствии переменных:
#   development  — варнинг, приложение запускается
#   production   — FATAL, приложение не запустится
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Обязателен Postgres (Supabase или другой). SQLite больше не поддерживается.
# DATABASE_URL — pooled connection (через pgbouncer), используется приложением.
# DIRECT_URL — прямое подключение, нужно для Prisma CLI (миграции).
DATABASE_URL=postgresql://user:password@host:5432/database?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/database

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Токен бота из @BotFather
TELEGRAM_BOT_TOKEN=

# Секрет для верификации webhook-запросов от Telegram
# Генерируйте: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Полный HTTPS URL вашего webhook endpoint
TELEGRAM_WEBHOOK_URL=https://your-domain.example/api/telegram/webhook

# Telegram API base URL (по умолчанию https://api.telegram.org)
# Замените на proxy/gateway при необходимости
TELEGRAM_API_BASE_URL=https://api.telegram.org

# ── Admin panel ───────────────────────────────────────────────────────────────
# Basic Auth для /admin. В development: если не заданы — открытый доступ.
# В production: обязательны. Приложение вернёт 503 если не заданы.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── Background jobs ───────────────────────────────────────────────────────────
# Секрет для защиты POST /api/jobs/refund-expired
# Если не задан — endpoint открыт (только для dev)
# Генерируйте: openssl rand -hex 32
CRON_JOB_SECRET=

# ── Commission (optional) ─────────────────────────────────────────────────────
# Комиссия в basis points (0-10000). По умолчанию: 50 (0.5%)
# 0 = без комиссии
GAME_COMMISSION_BPS=50

# Telegram user ID получателя комиссии
GAME_COMMISSION_RECIPIENT_TELEGRAM_USER_ID=

# ── Reserved / future ─────────────────────────────────────────────────────────
# TELEGRAM_PROXY_URL=
# TELEGRAM_PROXY_KIND=none
# TRUST_PROXY=false
# SUPABASE_PROJECT_REF=
# SUPABASE_SERVICE_ROLE_KEY=
