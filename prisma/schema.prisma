generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                     Int      @id @default(autoincrement())
  telegramUserId         String   @unique
  username               String?
  displayName            String?
  status                 UserStatus @default(active)
  regionCode             String?
  ageConfirmed           Boolean? @default(false)
  responsibleLimitPerDay Int?     @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  wallet      Wallet?
  games       Game[] @relation("CreatorGames")
  opponentGames Game[] @relation("OpponentGames")
  ledgerEntries LedgerEntry[]
  gamePlayers GamePlayer[]
  diceRolls   DiceRoll[]
}

enum UserStatus {
  active
  blocked
  under_review
}

model Wallet {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  currency          String   @default("USD")
  availableBalance  Int      @default(0)
  lockedBalance     Int      @default(0)
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  ledgerEntries LedgerEntry[]
}

model LedgerEntry {
  id              Int      @id @default(autoincrement())
  transactionId   String
  userId          Int
  walletId        Int
  gameId          Int?
  entryType       LedgerEntryType
  direction       LedgerDirection
  amount          Int
  currency        String   @default("USD")
  idempotencyKey  String?
  metadata        Json?
  createdAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  wallet Wallet @relation(fields: [walletId], references: [id])
  game   Game?  @relation(fields: [gameId], references: [id])
}

enum LedgerEntryType {
  admin_credit
  admin_debit
  escrow_lock
  escrow_release
  payout_credit
  refund_credit
  rake_debit
  adjustment
}

enum LedgerDirection {
  debit
  credit
}

model Game {
  id                Int      @id @default(autoincrement())
  publicCode        String   @unique
  creatorUserId     Int
  opponentUserId    Int?
  status            GameStatus @default(created)
  betAmount         Int
  currency          String   @default("USD")
  diceCount         Int
  winnerUserId      Int?
  loserUserId       Int?
  resultReason      String?
  expiresAt         DateTime
  settledAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  creator   User   @relation("CreatorGames", fields: [creatorUserId], references: [id])
  opponent  User?  @relation("OpponentGames", fields: [opponentUserId], references: [id])
  gamePlayers GamePlayer[]
  diceRolls   DiceRoll[]
  ledgerEntries LedgerEntry[]
}

enum GameStatus {
  created
  waiting
  matched
  rolling
  resolving
  settled
  cancelled
  refunded
  failed
  under_review
}

model GamePlayer {
  id                 Int      @id @default(autoincrement())
  gameId             Int
  userId             Int
  role               PlayerRole
  escrowLockedAmount Int      @default(0)
  joinedAt           DateTime @default(now())
  cancelledAt        DateTime?

  game  Game @relation(fields: [gameId], references: [id])
  user  User @relation(fields: [userId], references: [id])
}

enum PlayerRole {
  creator
  opponent
}

model DiceRoll {
  id              Int      @id @default(autoincrement())
  gameId          Int
  userId          Int
  rollRound       Int
  telegramChatId  String
  telegramMessageId String
  diceEmoji       String
  diceValue       Int
  diceCount       Int
  totalValue      Int
  source          DiceRollSource
  rawPayload      Json?
  createdAt       DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

enum DiceRollSource {
  telegram_dice
  admin_test
  system_test
}

model IdempotencyKey {
  key             String   @id
  operation       String
  resourceType    String
  resourceId      String
  responseSnapshot Json?
  createdAt       DateTime @default(now())
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actorType   ActorType
  actorId     Int
  action      String
  resourceType String
  resourceId  String
  metadata    Json?
  createdAt   DateTime @default(now())
}

enum ActorType {
  system
  admin
  user
  telegram_webhook
}